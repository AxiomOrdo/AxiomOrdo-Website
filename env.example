const triggers = [
  "A customer has asked for PFAS information",
  "Supplier data is incomplete or unclear",
  "Products are being prepared for market",
  "Internal approval needs a defensible position",
  "There is concern about regulatory exposure",
  "You need to know what can and cannot be supported today"
];

export function TriggerSection() {
  return (
    <section className="section section-dark">
      <div className="container">
        <div className="section-heading">
          <p className="eyebrow">Target condition</p>
          <h2>When companies come to us</h2>
          <p>
            Most teams do not have a PFAS problem because they ignored it. They
            have a PFAS problem because someone asked a harder question than
            they were ready to answer.
          </p>
        </div>

        <div className="card-grid small-gap">
          {triggers.map((trigger) => (
            <article className="trigger-card" key={trigger}>
              {trigger}
            </article>
          ))}
        </div>
      </div>
    </section>
  );
}
